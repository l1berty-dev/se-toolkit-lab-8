{
  "providers": {
    "custom": {
      "apiKey": "my-secret-qwen-key",
      "apiBase": "http://localhost:42005/v1"
    }
  },
  "agents": {
    "defaults": {
      "provider": "custom",
      "model": "coder-model"
    }
  },
  "tools": {
    "mcpServers": {
      "lms": {
        "command": "python",
        "args": [
          "-m",
          "mcp_lms"
        ],
        "env": {
          "NANOBOT_LMS_BACKEND_URL": "http://localhost:42002",
          "NANOBOT_LMS_API_KEY": "qwerty",
          "NANOBOT_VICTORIALOGS_URL": "http://victorialogs:9428",
          "NANOBOT_VICTORIATRACES_URL": "http://victoriatraces:10428"
        }
      }
    }
  },
  "channels": {
    "webchat": {
      "enabled": true,
      "allow_from": ["*"]
    }
  }
}
